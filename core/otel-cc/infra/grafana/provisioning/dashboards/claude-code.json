          "expr": "cc_project_tool_calls_total",
          "legendFormat": "{{project}}",
          "format": "table",
          "instant": true,
          "refId": "C"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": {
              "project": "Project",
              "Value #A": "Sessions",
              "Value #B": "Cost USD",
              "Value #C": "Tool Calls"
            }
          }
        }
      ]
    },

