              }},
              { "id": "custom.displayMode", "value": "color-background-solid" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Tool Calls" },
            "properties": [
              { "id": "unit", "value": "short" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Sessions" },
            "properties": [
              { "id": "unit", "value": "short" }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "cc_project_sessions_total",
